# Optional local development settings. Copy this file to .env and edit locally.
# .env is ignored by git.

# Prefer direct host executable path when the ShiroBot host is already built.
HOST_EXE=C:\\Path\\To\\ShiroBot\\bin\\Debug\\net10.0\\ShiroBot.exe

# Alternative: point to project root. HostExe will be derived as:
# <HOST_PROJECT_ROOT>/bin/Debug/<TargetFramework>/ShiroBot.exe
# HOST_PROJECT_ROOT=C:\\Path\\To\\ShiroBot\\
