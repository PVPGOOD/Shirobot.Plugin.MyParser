<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyParser.Provider.BiliBili.Views"
             x:Class="MyParser.Provider.BiliBili.Views.BiliLiveCard"
             x:DataType="vm:BiliLiveCardViewModel"
             Width="420" MinHeight="260">
    <Design.DataContext>
        <vm:BiliLiveCardViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Border.PremiumCard">
            <Setter Property="BoxShadow" Value="0 10 30 0 #26000000" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CardFallbackBg">#F5F5F5</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextPrimary">#1A1A1A</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextSecondary">#3F3F3F</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextMuted">#656565</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPanelBg">#D9FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPanelBorder">#33FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTagBg">#1A000000</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTagText">#4A4A4A</SolidColorBrush>
                    <SolidColorBrush x:Key="CardImageOverlay">#59FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="LiveBadgeBg">#FB7299</SolidColorBrush>
                    <SolidColorBrush x:Key="LiveBadgeText">#FFFFFF</SolidColorBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="CardFallbackBg">#121212</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextPrimary">#FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextSecondary">#ECECEC</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextMuted">#CCCCCC</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPanelBg">#3D000000</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPanelBorder">#1AFFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTagBg">#2BFFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTagText">#E5E5E5</SolidColorBrush>
                    <SolidColorBrush x:Key="CardImageOverlay">#73000000</SolidColorBrush>
                    <SolidColorBrush x:Key="LiveBadgeBg">#FB7299</SolidColorBrush>
                    <SolidColorBrush x:Key="LiveBadgeText">#FFFFFF</SolidColorBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Classes="PremiumCard"
            Width="420"
            MinHeight="260"
            CornerRadius="12"
            ClipToBounds="True"
            Background="{DynamicResource CardFallbackBg}">
        <Grid>
            <Border Margin="-48">
                <Border.Effect>
                    <BlurEffect Radius="28" />
                </Border.Effect>
                <Border.Background>
                    <ImageBrush Source="{Binding Cover}" Stretch="UniformToFill" />
                </Border.Background>
            </Border>
            <Border Background="{DynamicResource CardImageOverlay}" />

            <StackPanel Margin="22" Spacing="16">
                <Grid ColumnDefinitions="*,Auto">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border Width="44" Height="44" CornerRadius="22" BorderBrush="#FB7299" BorderThickness="1.5" ClipToBounds="True" Margin="0,0,12,0">
                            <Image Source="{Binding Avatar}" Width="44" Height="44" Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="{Binding AnchorName}"
                                       Foreground="{DynamicResource CardTextPrimary}"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       MaxWidth="210"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                        <Border Background="{DynamicResource LiveBadgeBg}" CornerRadius="8" Padding="9,5">
                            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource LiveBadgeText}" FontSize="12" FontWeight="Bold" />
                        </Border>
                        <Border Background="{DynamicResource CardTagBg}" CornerRadius="8" Padding="9,5">
                            <TextBlock Text="{Binding KindText}" Foreground="{DynamicResource CardTagText}" FontSize="12" FontWeight="Medium" />
                        </Border>
                    </StackPanel>
                </Grid>

                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding Title}"
                               Foreground="{DynamicResource CardTextPrimary}"
                               FontSize="20"
                               FontWeight="Heavy"
                               TextWrapping="Wrap"
                               MaxLines="2"
                               LineHeight="27" />
                    <TextBlock Text="{Binding RoomIdText}"
                               Foreground="{DynamicResource CardTextSecondary}"
                               FontSize="14"
                               FontWeight="SemiBold" />
                </StackPanel>

                <Border Background="{DynamicResource CardPanelBg}"
                        BorderBrush="{DynamicResource CardPanelBorder}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14,12">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="12">
                        <StackPanel Spacing="3">
                            <TextBlock Text="房间观众" Foreground="{DynamicResource CardTextMuted}" FontSize="11" />
                            <TextBlock Text="{Binding AudienceText}" Foreground="{DynamicResource CardTextPrimary}" FontSize="14" FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="3">
                            <TextBlock Text="人气/看过" Foreground="{DynamicResource CardTextMuted}" FontSize="11" />
                            <TextBlock Text="{Binding WatchedText}" Foreground="{DynamicResource CardTextPrimary}" FontSize="14" FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Spacing="3">
                            <TextBlock Text="开播时间" Foreground="{DynamicResource CardTextMuted}" FontSize="11" />
                            <TextBlock Text="{Binding LiveStartTimeText}" Foreground="{DynamicResource CardTextPrimary}" FontSize="13" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="3">
                            <TextBlock Text="直播时长" Foreground="{DynamicResource CardTextMuted}" FontSize="11" />
                            <TextBlock Text="{Binding LiveDurationText}" Foreground="{DynamicResource CardTextPrimary}" FontSize="13" FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
