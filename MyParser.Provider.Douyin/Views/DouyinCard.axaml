<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyParser.Provider.Douyin.Views"
             x:Class="MyParser.Provider.Douyin.Views.DouyinCard"
             x:DataType="vm:DouyinCardViewModel"
             Width="360" Height="640">

    <Design.DataContext>
        <vm:DouyinCardViewModel />
    </Design.DataContext>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CardBackground">#F1F5F9</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextPrimary">#0F172A</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextSecondary">#475569</SolidColorBrush>
                    <SolidColorBrush x:Key="CardButtonBackground">#F2FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardButtonBorder">#1A000000</SolidColorBrush>
                    <SolidColorBrush x:Key="CardButtonText">#334155</SolidColorBrush>
                    <LinearGradientBrush x:Key="TopScrim" StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#90FFFFFF" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                    <LinearGradientBrush x:Key="BottomScrim" StartPoint="0%,100%" EndPoint="0%,0%">
                        <GradientStop Color="#F2F1F5F9" Offset="0" />
                        <GradientStop Color="#A6F1F5F9" Offset="0.4" />
                        <GradientStop Color="#00F1F5F9" Offset="1" />
                    </LinearGradientBrush>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="CardBackground">#0F172A</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextPrimary">#FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextSecondary">#94A3B8</SolidColorBrush>
                    <SolidColorBrush x:Key="CardButtonBackground">#33000000</SolidColorBrush>
                    <SolidColorBrush x:Key="CardButtonBorder">#1AFFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardButtonText">#FFFFFF</SolidColorBrush>
                    <LinearGradientBrush x:Key="TopScrim" StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#80000000" Offset="0" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </LinearGradientBrush>
                    <LinearGradientBrush x:Key="BottomScrim" StartPoint="0%,100%" EndPoint="0%,0%">
                        <GradientStop Color="#E6000000" Offset="0" />
                        <GradientStop Color="#66000000" Offset="0.4" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </LinearGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.SidebarBtn">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Background" Value="{DynamicResource CardButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="Border.TagPill">
            <Setter Property="Background" Value="{DynamicResource CardButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>
    </UserControl.Styles>

    <Border CornerRadius="12" ClipToBounds="True" Background="{DynamicResource CardBackground}">
        <Grid>
            <!-- 保持封面原始比例完整展示，避免 UniformToFill 放大裁剪客户端封面 -->
            <Image Source="{Binding Cover}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />

            <Border VerticalAlignment="Top" Height="128" IsHitTestVisible="False" Background="{DynamicResource TopScrim}" />
            <Border VerticalAlignment="Bottom" Height="420" IsHitTestVisible="False" Background="{DynamicResource BottomScrim}" />

            <Grid VerticalAlignment="Top" Height="80" Margin="16,0,16,0">
                <Border Background="{DynamicResource CardButtonBackground}"
                        BorderBrush="{DynamicResource CardButtonBorder}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12,6"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding DurationText}" Foreground="{DynamicResource CardButtonText}" FontSize="12" FontWeight="Medium" />
                </Border>
            </Grid>

            <Grid Margin="16,0,16,24" VerticalAlignment="Bottom" ColumnDefinitions="*,60">
                <StackPanel Grid.Column="0" VerticalAlignment="Bottom" Spacing="10" Margin="0,0,10,0">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{Binding AuthorName}" Foreground="{DynamicResource CardTextPrimary}" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="{Binding AuthorMeta}" Foreground="{DynamicResource CardTextSecondary}" FontSize="11" FontWeight="Medium" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="{DynamicResource CardTextPrimary}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   MaxLines="3" />
                        <TextBlock Text="{Binding Description}"
                                   Foreground="{DynamicResource CardTextSecondary}"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   MaxLines="2" />
                    </StackPanel>

                    <Border Background="{DynamicResource CardButtonBackground}"
                            BorderBrush="{DynamicResource CardButtonBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,6">
                        <TextBlock Text="{Binding TagsText}"
                                   Foreground="{DynamicResource CardButtonText}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   MaxLines="2" />
                    </Border>

                    <Border Background="{DynamicResource CardButtonBackground}"
                            BorderBrush="{DynamicResource CardButtonBorder}"
                            BorderThickness="1"
                            CornerRadius="15"
                            Padding="6,6,12,6"
                            HorizontalAlignment="Left"
                            MaxWidth="220">
                        <Grid ColumnDefinitions="22,*">
                            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11" Background="#333333" BorderBrush="#33FFFFFF" BorderThickness="1">
                                <PathIcon Data="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"
                                          Width="10" Height="10" Foreground="White" />
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding MusicText}"
                                       Foreground="{DynamicResource CardButtonText}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Spacing="16" HorizontalAlignment="Center">
                    <Grid Width="46" Height="52">
                        <Border Width="46" Height="46" CornerRadius="23" BorderBrush="White" BorderThickness="2"
                                ClipToBounds="True" VerticalAlignment="Top" Background="White">
                            <Image Source="{Binding Avatar}" Stretch="UniformToFill" />
                        </Border>
                        <Border Width="20" Height="20" CornerRadius="10" Background="#EF4444"
                                HorizontalAlignment="Center" VerticalAlignment="Bottom" BorderBrush="{DynamicResource CardBackground}" BorderThickness="1.5">
                            <PathIcon Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" Width="10" Height="10" Foreground="White" />
                        </Border>
                    </Grid>

                    <StackPanel Spacing="4">
                        <Button Classes="SidebarBtn">
                            <PathIcon Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                                      Width="20" Height="20" Foreground="{DynamicResource CardButtonText}" />
                        </Button>
                        <TextBlock Text="{Binding LikeCount}" Foreground="{DynamicResource CardTextPrimary}" FontSize="11" HorizontalAlignment="Center" FontWeight="SemiBold" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <Button Classes="SidebarBtn">
                            <PathIcon Data="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"
                                      Width="20" Height="20" Foreground="{DynamicResource CardButtonText}" />
                        </Button>
                        <TextBlock Text="{Binding CommentCount}" Foreground="{DynamicResource CardTextPrimary}" FontSize="11" HorizontalAlignment="Center" FontWeight="SemiBold" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <Button Classes="SidebarBtn">
                            <PathIcon Data="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"
                                      Width="20" Height="20" Foreground="#FACC15" />
                        </Button>
                        <TextBlock Text="{Binding CollectCount}" Foreground="{DynamicResource CardTextPrimary}" FontSize="11" HorizontalAlignment="Center" FontWeight="SemiBold" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <Button Classes="SidebarBtn">
                            <PathIcon Data="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"
                                      Width="20" Height="20" Foreground="{DynamicResource CardButtonText}" />
                        </Button>
                        <TextBlock Text="{Binding ShareCount}" Foreground="{DynamicResource CardTextPrimary}" FontSize="11" HorizontalAlignment="Center" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
