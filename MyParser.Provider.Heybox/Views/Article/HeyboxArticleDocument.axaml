<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MyParser.Provider.Heybox.Views.HeyboxArticleDocument"
             x:CompileBindings="False"
             Width="720"
             Height="{Binding CanvasHeight}">

    <UserControl.Styles>
        <Style Selector="Border.PremiumCard">
            <Setter Property="BoxShadow" Value="0 8 24 0 #1A000000" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CardFallbackBg">#F5F7FA</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextPrimary">#14191E</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextSecondary">#344352</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextMuted">#5D6B78</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPanelBg">#D9FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPanelBorder">#33FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTagBg">#1A000000</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTagText">#344352</SolidColorBrush>
                    <SolidColorBrush x:Key="HeyboxAccent">#008AB8</SolidColorBrush>
                    <SolidColorBrush x:Key="HeyboxAccentText">#FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardImageOverlay">#66FFFFFF</SolidColorBrush>
                    <LinearGradientBrush x:Key="HeaderScrim" StartPoint="0%,100%" EndPoint="0%,0%">
                        <GradientStop Color="#F2F5F7FA" Offset="0" />
                        <GradientStop Color="#CCF5F7FA" Offset="0.45" />
                        <GradientStop Color="#00F5F7FA" Offset="1" />
                    </LinearGradientBrush>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="CardFallbackBg">#101820</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextPrimary">#FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextSecondary">#E8EEF4</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextMuted">#C4D0DA</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPanelBg">#40000000</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPanelBorder">#1AFFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTagBg">#2BFFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTagText">#E8EEF4</SolidColorBrush>
                    <SolidColorBrush x:Key="HeyboxAccent">#00C2EE</SolidColorBrush>
                    <SolidColorBrush x:Key="HeyboxAccentText">#052B36</SolidColorBrush>
                    <SolidColorBrush x:Key="CardImageOverlay">#66000000</SolidColorBrush>
                    <LinearGradientBrush x:Key="HeaderScrim" StartPoint="0%,100%" EndPoint="0%,0%">
                        <GradientStop Color="#F2101820" Offset="0" />
                        <GradientStop Color="#A6101820" Offset="0.5" />
                        <GradientStop Color="#00101820" Offset="1" />
                    </LinearGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Classes="PremiumCard"
            Width="720"
            Height="{Binding CanvasHeight}"
            CornerRadius="8"
            ClipToBounds="True"
            Background="{DynamicResource CardFallbackBg}">
        <Grid>
            <!-- 参考 Bilibili 文章：封面毛玻璃背景 + 半透明遮罩，整体和视频卡片统一。 -->
            <Border Margin="-48">
                <Border.Effect>
                    <BlurEffect Radius="30" />
                </Border.Effect>
                <Border.Background>
                    <ImageBrush Source="{Binding Cover}" Stretch="UniformToFill" />
                </Border.Background>
            </Border>
            <Border Background="{DynamicResource CardImageOverlay}" />

            <StackPanel Margin="48,44,48,44" Spacing="22">
                <!-- 顶部 Hero 区域：封面、作者、标题、数据放在一个玻璃 panel 内。 -->
                <Border CornerRadius="18"
                        ClipToBounds="True"
                        Background="{DynamicResource CardPanelBg}"
                        BorderBrush="{DynamicResource CardPanelBorder}"
                        BorderThickness="1">
                    <Grid RowDefinitions="220,Auto">
                        <Grid Grid.Row="0">
                            <Image Source="{Binding Cover}" Stretch="UniformToFill" />
                            <Border Background="{DynamicResource HeaderScrim}" />

                            <Grid VerticalAlignment="Top" Margin="18" ColumnDefinitions="*,Auto">
                                <Border Background="{DynamicResource HeyboxAccent}"
                                        CornerRadius="8"
                                        Padding="10,5"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding KindText}"
                                               Foreground="{DynamicResource HeyboxAccentText}"
                                               FontSize="12"
                                               FontWeight="Black"
                                               LetterSpacing="0.4" />
                                </Border>

                                <Border Grid.Column="1"
                                        Background="{DynamicResource CardPanelBg}"
                                        BorderBrush="{DynamicResource CardPanelBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,5">
                                    <TextBlock Text="小黑盒 / Heybox"
                                               Foreground="{DynamicResource CardTextSecondary}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Grid>

                        <StackPanel Grid.Row="1" Margin="22,18,22,22" Spacing="16">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Grid Width="46" Height="46" Margin="0,0,14,0">
                                    <Border CornerRadius="23" ClipToBounds="True" BorderBrush="{DynamicResource HeyboxAccent}" BorderThickness="1.5" Background="{DynamicResource CardPanelBg}">
                                        <Image Source="{Binding Avatar}" Stretch="UniformToFill" />
                                    </Border>
                                    <Border Background="{DynamicResource HeyboxAccent}" Width="16" Height="16" CornerRadius="8"
                                            BorderBrush="#111111" BorderThickness="1"
                                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,-2">
                                        <TextBlock Text="盒" FontSize="8" Foreground="{DynamicResource HeyboxAccentText}" FontWeight="Black"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                                    <TextBlock Text="{Binding AuthorName}" Foreground="{DynamicResource CardTextPrimary}" FontSize="18" FontWeight="Bold" />
                                    <TextBlock Text="{Binding MetaText}" Foreground="{DynamicResource CardTextMuted}" FontSize="12" FontWeight="Medium" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="{Binding Title}"
                                       Foreground="{DynamicResource CardTextPrimary}"
                                       FontSize="27"
                                       FontWeight="Heavy"
                                       TextWrapping="Wrap"
                                       LineHeight="35" />

                            <Border Background="{DynamicResource CardTagBg}" CornerRadius="10" Padding="12,8">
                                <TextBlock Text="{Binding StatsText}"
                                           Foreground="{DynamicResource CardTagText}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <ItemsControl ItemsSource="{Binding Blocks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="8" Margin="0,0,0,12">
                                <Border IsVisible="{Binding IsImage}"
                                        CornerRadius="14"
                                        ClipToBounds="True"
                                        Background="{DynamicResource CardPanelBg}"
                                        BorderBrush="{DynamicResource CardPanelBorder}"
                                        BorderThickness="1"
                                        Height="{Binding Height}">
                                    <Image Source="{Binding Image}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock IsVisible="{Binding IsImage}"
                                           Text="{Binding Caption}"
                                           Foreground="{DynamicResource CardTextMuted}"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap" />

                                <Grid IsVisible="{Binding IsText}" Margin="{Binding Margin}" ColumnDefinitions="Auto,*">
                                    <Border Grid.Column="0"
                                            IsVisible="{Binding HasAccent}"
                                            Width="{Binding AccentWidth}"
                                            CornerRadius="999"
                                            Background="{Binding AccentBrush}"
                                            Margin="0,4,10,4" />
                                    <Border Grid.Column="1"
                                            CornerRadius="10"
                                            Background="{Binding Background}"
                                            BorderBrush="{Binding BorderBrush}"
                                            BorderThickness="1"
                                            Padding="10,8">
                                        <TextBlock Text="{Binding Text}"
                                                   Foreground="{Binding Foreground}"
                                                   FontSize="{Binding FontSize}"
                                                   FontWeight="{Binding FontWeight}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="{Binding LineHeight}" />
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
