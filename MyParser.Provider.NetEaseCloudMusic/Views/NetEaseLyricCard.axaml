<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyParser.Provider.NetEaseCloudMusic.Views"
             x:Class="MyParser.Provider.NetEaseCloudMusic.Views.NetEaseLyricCard"
             x:DataType="vm:NetEaseLyricCardViewModel"
             Width="500" Height="{Binding CardHeight}">
    <Design.DataContext>
        <vm:NetEaseLyricCardViewModel />
    </Design.DataContext>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CardFallbackBg">#F8FAFC</SolidColorBrush>
                    <SolidColorBrush x:Key="CardOverlay">#EFFFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextPrimary">#0F172A</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextSecondary">#475569</SolidColorBrush>
                    <SolidColorBrush x:Key="CardLyricText">#1E293B</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPanelBg">#D9FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPanelBorder">#18000000</SolidColorBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="CardFallbackBg">#0F172A</SolidColorBrush>
                    <SolidColorBrush x:Key="CardOverlay">#CC000000</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextPrimary">#FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextSecondary">#CBD5E1</SolidColorBrush>
                    <SolidColorBrush x:Key="CardLyricText">#F8FAFC</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPanelBg">#33000000</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPanelBorder">#22FFFFFF</SolidColorBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border CornerRadius="14" ClipToBounds="True" Background="{DynamicResource CardFallbackBg}">
        <Grid>
            <Border Margin="-36">
                <Border.Effect>
                    <BlurEffect Radius="28" />
                </Border.Effect>
                <Border.Background>
                    <ImageBrush Source="{Binding Cover}" Stretch="UniformToFill" />
                </Border.Background>
            </Border>
            <Border Background="{DynamicResource CardOverlay}" />

            <Grid Margin="18" RowDefinitions="Auto,*" RowSpacing="10">
                <Grid Grid.Row="0" ColumnDefinitions="48,*">
                    <Border Width="42" Height="42" CornerRadius="8" ClipToBounds="True" Background="#22000000"
                            BoxShadow="0 4 12 0 #55000000">
                        <Image Source="{Binding Cover}" Stretch="UniformToFill" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{Binding SourceText}" Foreground="#E60026" FontSize="9" FontWeight="Bold" />
                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource CardTextPrimary}" FontSize="15" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Artists}" Foreground="{DynamicResource CardTextSecondary}" FontSize="10" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Background="{DynamicResource CardPanelBg}"
                        BorderBrush="{DynamicResource CardPanelBorder}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14,12">
                    <TextBlock Text="{Binding LyricText}"
                               Foreground="{DynamicResource CardLyricText}"
                               FontSize="13"
                               LineHeight="18"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
