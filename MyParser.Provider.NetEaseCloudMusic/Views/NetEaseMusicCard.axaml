<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyParser.Provider.NetEaseCloudMusic.Views"
             x:Class="MyParser.Provider.NetEaseCloudMusic.Views.NetEaseMusicCard"
             x:DataType="vm:NetEaseMusicCardViewModel"
             Width="360" Height="190">
    <Design.DataContext>
        <vm:NetEaseMusicCardViewModel />
    </Design.DataContext>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CardFallbackBg">#F8FAFC</SolidColorBrush>
                    <SolidColorBrush x:Key="CardOverlay">#D9FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextPrimary">#0F172A</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextSecondary">#475569</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPillBg">#E6FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPillBorder">#22000000</SolidColorBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="CardFallbackBg">#111827</SolidColorBrush>
                    <SolidColorBrush x:Key="CardOverlay">#B3000000</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextPrimary">#FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextSecondary">#CBD5E1</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPillBg">#33000000</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPillBorder">#26FFFFFF</SolidColorBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border CornerRadius="14" ClipToBounds="True" Background="{DynamicResource CardFallbackBg}">
        <Grid>
            <Border Margin="-28">
                <Border.Effect>
                    <BlurEffect Radius="24" />
                </Border.Effect>
                <Border.Background>
                    <ImageBrush Source="{Binding Cover}" Stretch="UniformToFill" />
                </Border.Background>
            </Border>
            <Border Background="{DynamicResource CardOverlay}" />

            <Grid ColumnDefinitions="124,*" Margin="18">
                <Border Width="116" Height="116" CornerRadius="12" ClipToBounds="True" Background="#22000000"
                        BoxShadow="0 8 20 0 #66000000" VerticalAlignment="Center">
                    <Grid>
                        <Image Source="{Binding Cover}" Stretch="UniformToFill" />
                        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,8"
                                Width="26" Height="26" CornerRadius="13" Background="#D9E60026">
                            <PathIcon Data="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"
                                      Width="14" Height="14" Foreground="White" />
                        </Border>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Spacing="7" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Border Background="#E60026" CornerRadius="9" Padding="8,3" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding SourceText}" Foreground="White" FontSize="10" FontWeight="Bold" />
                    </Border>
                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource CardTextPrimary}" FontSize="18" FontWeight="Bold"
                               TextWrapping="Wrap" MaxLines="2" />
                    <TextBlock Text="{Binding Artists}" Foreground="{DynamicResource CardTextSecondary}" FontSize="13"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Album}" Foreground="{DynamicResource CardTextSecondary}" FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                    <WrapPanel Margin="0,4,0,0">
                        <Border Background="{DynamicResource CardPillBg}" BorderBrush="{DynamicResource CardPillBorder}" BorderThickness="1" CornerRadius="8" Padding="7,3" Margin="0,0,5,5">
                            <TextBlock Text="{Binding QualityText}" Foreground="{DynamicResource CardTextPrimary}" FontSize="10" />
                        </Border>
                        <Border Background="{DynamicResource CardPillBg}" BorderBrush="{DynamicResource CardPillBorder}" BorderThickness="1" CornerRadius="8" Padding="7,3" Margin="0,0,5,5">
                            <TextBlock Text="{Binding SizeText}" Foreground="{DynamicResource CardTextPrimary}" FontSize="10" />
                        </Border>
                        <Border Background="{DynamicResource CardPillBg}" BorderBrush="{DynamicResource CardPillBorder}" BorderThickness="1" CornerRadius="8" Padding="7,3" Margin="0,0,5,5">
                            <TextBlock Text="{Binding BitrateText}" Foreground="{DynamicResource CardTextPrimary}" FontSize="10" />
                        </Border>
                    </WrapPanel>
                    <TextBlock Text="{Binding SongIdText}" Foreground="{DynamicResource CardTextSecondary}" FontSize="10" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
