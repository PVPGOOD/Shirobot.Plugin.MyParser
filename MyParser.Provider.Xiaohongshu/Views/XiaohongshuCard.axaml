<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MyParser.Provider.Xiaohongshu.Views"
             x:Class="MyParser.Provider.Xiaohongshu.Views.XiaohongshuCard"
             x:DataType="vm:XiaohongshuCardViewModel"
             Width="760" Height="520">

    <Design.DataContext>
        <vm:XiaohongshuCardViewModel />
    </Design.DataContext>

    <Border Width="760" Height="520" CornerRadius="28" ClipToBounds="True" Background="#121216">
        <Canvas Width="760" Height="520">
            <Image Canvas.Left="0" Canvas.Top="0" Width="760" Height="520" Source="{Binding Cover}" Stretch="UniformToFill" Opacity="0.14" />
            <Border Canvas.Left="0" Canvas.Top="0" Width="760" Height="520" Background="#E8121216" />
            <Ellipse Canvas.Left="-90" Canvas.Top="-100" Width="260" Height="260" Fill="#38FF2442" />
            <Ellipse Canvas.Left="520" Canvas.Top="340" Width="280" Height="280" Fill="#24FFD1DC" />

            <Border Canvas.Left="24" Canvas.Top="24" Width="328" Height="472" CornerRadius="24" ClipToBounds="True" Background="#202027" BorderBrush="#30FFFFFF" BorderThickness="1">
                <Grid>
                    <Image Source="{Binding Cover}" Stretch="UniformToFill" />
                    <Border VerticalAlignment="Bottom" Height="140">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                <GradientStop Color="#00000000" Offset="0" />
                                <GradientStop Color="#D9000000" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14" CornerRadius="999" Padding="12,6" Background="#E8FF2442">
                        <TextBlock Text="{Binding KindText}" Foreground="#FFFFFFFF" FontSize="12" FontWeight="Bold" />
                    </Border>
                    <StackPanel VerticalAlignment="Bottom" Margin="18" Spacing="6">
                        <TextBlock Text="{Binding Title}" Foreground="#FFFFFFFF" FontSize="22" FontWeight="Bold" TextWrapping="Wrap" MaxLines="3" LineHeight="28" />
                        <TextBlock Text="{Binding StatsText}" Foreground="#FFE7E0E6" FontSize="12" TextWrapping="Wrap" MaxLines="2" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Canvas.Left="374" Canvas.Top="24" Width="362" Height="472" CornerRadius="24" Background="#F51F1B20" BorderBrush="#30FFFFFF" BorderThickness="1" Padding="18">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="46,*,Auto" Height="46">
                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" ClipToBounds="True" Background="#302A2F" BorderBrush="#FFFF2442" BorderThickness="2">
                            <Image Source="{Binding Avatar}" Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{Binding AuthorName}" Foreground="#FFF7F0F5" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding MetaText}" Foreground="#FFCFC4CC" FontSize="11" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Border Grid.Column="2" VerticalAlignment="Center" CornerRadius="999" Padding="9,5" Background="#33FF2442">
                            <TextBlock Text="XHS" Foreground="#FFFFD9DE" FontSize="10" FontWeight="Bold" />
                        </Border>
                    </Grid>

                    <TextBlock Text="{Binding Description}" Foreground="#FFEFE7ED" FontSize="14" TextWrapping="Wrap" MaxLines="4" LineHeight="20" />
                    <TextBlock Text="{Binding TagsText}" Foreground="#FFFFB3C0" FontSize="12" TextWrapping="Wrap" MaxLines="2" />

                    <Border Height="98" CornerRadius="18" ClipToBounds="True" Background="#26222A" BorderBrush="#24FFFFFF" BorderThickness="1">
                        <Grid ColumnDefinitions="124,*">
                            <Image Grid.Column="0" Source="{Binding SecondImage}" Stretch="UniformToFill" />
                            <StackPanel Grid.Column="1" Margin="12" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="第二张图片" Foreground="#FFFFD9DE" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Text="图文问答场景：左侧主封面，右侧保留第二张图片与前 10 条评论。" Foreground="#FFCFC4CC" FontSize="11" TextWrapping="Wrap" MaxLines="3" LineHeight="16" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Height="246" CornerRadius="18" Background="#221E25" BorderBrush="#24FFFFFF" BorderThickness="1" Padding="12">
                        <StackPanel Spacing="7">
                            <TextBlock Text="前 10 条评论" Foreground="#FFFFFFFF" FontSize="14" FontWeight="Bold" />
                            <ItemsControl ItemsSource="{Binding Comments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:XiaohongshuCommentViewModel">
                                        <Grid ColumnDefinitions="24,*" Margin="0,0,0,6">
                                            <Border Grid.Column="0" Width="18" Height="18" CornerRadius="9" Background="#44FF2442" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Index}" Foreground="#FFFFD9DE" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="1">
                                                <TextBlock Text="{Binding Nickname}" Foreground="#FFFFD9DE" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Content}" Foreground="#FFECE6EB" FontSize="11" TextWrapping="Wrap" MaxLines="2" LineHeight="15" />
                                                <TextBlock Text="{Binding Meta}" Foreground="#FF9D929B" FontSize="9" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Canvas>
    </Border>
</UserControl>
