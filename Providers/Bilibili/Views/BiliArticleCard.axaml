<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Shirobot.Plugin.MyParser.Providers.Bilibili.ViewModels"
             x:Class="Shirobot.Plugin.MyParser.Providers.Bilibili.Views.BiliArticleCard"
             x:DataType="vm:BiliArticleCardViewModel"
             Width="360" Height="640">
    <Design.DataContext>
        <vm:BiliArticleCardViewModel />
    </Design.DataContext>

    <Border Width="360" Height="640" CornerRadius="28" ClipToBounds="True" Background="#101014">
        <Canvas Width="360" Height="640">
            <Image Canvas.Left="0" Canvas.Top="0" Width="360" Height="640" Source="{Binding Cover}" Stretch="UniformToFill" Opacity="0.18" />
            <Border Canvas.Left="0" Canvas.Top="0" Width="360" Height="640" Background="#DD101014" />
            <Ellipse Canvas.Left="-70" Canvas.Top="-80" Width="220" Height="220" Fill="#30FB7299" />
            <Ellipse Canvas.Left="230" Canvas.Top="120" Width="170" Height="170" Fill="#2400AEEC" />

            <Border Canvas.Left="20" Canvas.Top="24" Width="320" Height="96" CornerRadius="24" Background="#F41D1B20" BorderBrush="#30CAC4D0" BorderThickness="1" Padding="14">
                <Grid ColumnDefinitions="52,*,Auto">
                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" ClipToBounds="True" Background="#2B2930" BorderBrush="#FB7299" BorderThickness="2" VerticalAlignment="Center">
                        <Image Source="{Binding Avatar}" Stretch="UniformToFill" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding AuthorName}" Foreground="#F4EFF4" FontSize="14" FontWeight="SemiBold" MaxWidth="150" TextTrimming="CharacterEllipsis" />
                            <Border Background="#FB7299" CornerRadius="999" Padding="6,2" VerticalAlignment="Center">
                                <TextBlock Text="UP" Foreground="White" FontSize="9" FontWeight="Bold" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding AuthorMeta}" Foreground="#CAC4D0" FontSize="11" MaxWidth="200" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Border Grid.Column="2" CornerRadius="999" Background="#29FB7299" Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding KindText}" Foreground="#FFD8E7" FontSize="10" FontWeight="SemiBold" />
                    </Border>
                </Grid>
            </Border>

            <Border Canvas.Left="20" Canvas.Top="136" Width="320" Height="182" CornerRadius="24" ClipToBounds="True" Background="#1B1B20" BorderBrush="#33FFFFFF" BorderThickness="1">
                <Grid>
                    <Image Source="{Binding Cover}" Stretch="UniformToFill" />
                    <Border Background="#66000000" />
                    <TextBlock Text="{Binding ImageCountText}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,12,12" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                </Grid>
            </Border>

            <Border Canvas.Left="20" Canvas.Top="334" Width="320" Height="282" CornerRadius="28" Background="#F41D1B20" BorderBrush="#30CAC4D0" BorderThickness="1" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding Title}" Foreground="#F4EFF4" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="3" LineHeight="24" />
                    <TextBlock Text="{Binding Summary}" Foreground="#CAC4D0" FontSize="12" TextWrapping="Wrap" MaxLines="5" LineHeight="18" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border CornerRadius="999" Padding="10,5" Background="#2A00AEEC" BorderBrush="#6600AEEC" BorderThickness="1">
                            <TextBlock Text="{Binding TagsText}" Foreground="#A6EDFF" FontSize="11" FontWeight="Medium" MaxWidth="160" TextTrimming="CharacterEllipsis" />
                        </Border>
                        <Border CornerRadius="999" Padding="10,5" Background="#2AFB7299" BorderBrush="#66FB7299" BorderThickness="1">
                            <TextBlock Text="{Binding PublishTimeText}" Foreground="#FFD8E7" FontSize="11" FontWeight="Medium" />
                        </Border>
                    </StackPanel>
                    <Border CornerRadius="18" Background="#2B2930" BorderBrush="#30CAC4D0" BorderThickness="1" Padding="12,10">
                        <TextBlock Text="{Binding StatsText}" Foreground="#F4EFF4" FontSize="12" TextWrapping="Wrap" LineHeight="18" />
                    </Border>
                </StackPanel>
            </Border>
        </Canvas>
    </Border>
</UserControl>
