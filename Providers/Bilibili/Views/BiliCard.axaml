<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Shirobot.Plugin.MyParser.Providers.Bilibili.ViewModels"
             x:Class="Shirobot.Plugin.MyParser.Providers.Bilibili.Views.BiliCard"
             x:DataType="vm:BiliCardViewModel"
             Width="360" MinHeight="150">
     <Design.DataContext>
        <vm:BiliCardViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Border.PremiumCard">
            <!-- 移除了缩放动作与过渡动画，仅保留高级感阴影 -->
            <Setter Property="BoxShadow" Value="0 8 24 0 #1A000000"/>
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="CardFallbackBg">#F5F5F5</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextPrimary">#1A1A1A</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextSecondary">#3F3F3F</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextMuted">#656565</SolidColorBrush> <!-- 优化：加深简介灰色, 提高清晰度 -->
                    <SolidColorBrush x:Key="CardPanelBg">#CCFFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPanelBorder">#33FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTagBg">#1A000000</SolidColorBrush> <!-- 优化：加深标签背景 -->
                    <SolidColorBrush x:Key="CardTagText">#4A4A4A</SolidColorBrush> <!-- 优化：使标签文本比简介稍深 -->
                    <SolidColorBrush x:Key="CardShareColor">#5F5F5F</SolidColorBrush>
                    
                    <SolidColorBrush x:Key="CardImageOverlay">#4DFFFFFF</SolidColorBrush> <!-- 优化：浅色模式下增加30%白遮罩提高文本识别度 -->
                    
                    <!-- 优化：浅色模式下半透明时间挂件 -->
                    <SolidColorBrush x:Key="DurationBg">#59000000</SolidColorBrush>
                    <SolidColorBrush x:Key="DurationBorder">#1AFFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="DurationText">#FFFFFF</SolidColorBrush>
                </ResourceDictionary>
                
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="CardFallbackBg">#121212</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextPrimary">#FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextSecondary">#ECECEC</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTextMuted">#CCCCCC</SolidColorBrush> <!-- 优化：亮化深色简介，避免在暗影下模糊 -->
                    <SolidColorBrush x:Key="CardPanelBg">#33000000</SolidColorBrush>
                    <SolidColorBrush x:Key="CardPanelBorder">#1AFFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="CardTagBg">#2BFFFFFF</SolidColorBrush> <!-- 优化：亮化标签背景 -->
                    <SolidColorBrush x:Key="CardTagText">#E5E5E5</SolidColorBrush> <!-- 优化：亮化标签文字 -->
                    <SolidColorBrush x:Key="CardShareColor">#FFFFFF</SolidColorBrush>
                    
                    <SolidColorBrush x:Key="CardImageOverlay">#66000000</SolidColorBrush>
                    
                    <!-- 优化：深色模式下半透明时间挂件 -->
                    <SolidColorBrush x:Key="DurationBg">#4D000000</SolidColorBrush>
                    <SolidColorBrush x:Key="DurationBorder">#1AFFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="DurationText">#EAEAEA</SolidColorBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            
            <SolidColorBrush x:Key="YellowVBorder">#111111</SolidColorBrush>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Classes="PremiumCard"
            Width="360" MinHeight="150" 
            CornerRadius="8" 
            ClipToBounds="True" 
            Background="{DynamicResource CardFallbackBg}"
            >
        
        <Grid>
            <!-- 毛玻璃模糊背景图：增加 Margin="-40" 将黑边推到可视范围外，从而被外层裁剪掉 -->
            <Border Margin="-40">
                <Border.Effect>
                    <BlurEffect Radius="26"></BlurEffect>
                </Border.Effect>
                <Border.Background>
                    <ImageBrush Source="{Binding Cover}" Stretch="UniformToFill" />
                </Border.Background>
            </Border>

            <!-- 纯色遮罩层 -->
            <Border Background="{DynamicResource CardImageOverlay}"/>

            <!-- 顶部时长挂件 (优化: 使用半透明玻璃感并加上细边框) -->
            <Border VerticalAlignment="Top" HorizontalAlignment="Right" 
                    Margin="12 24 12  12" Padding="8,4" 
                    Background="{DynamicResource DurationBg}" 
                    BorderBrush="{DynamicResource DurationBorder}"
                    BorderThickness="1"
                    CornerRadius="8">
                <TextBlock Text="{Binding DurationText}" 
                           Foreground="{DynamicResource DurationText}" 
                           FontSize="11" 
                           FontWeight="Medium" 
                           LetterSpacing="0.5"/>
            </Border>

            <!-- 内容区 -->
            <StackPanel VerticalAlignment="Bottom" Margin="20" Spacing="16">
                
                <StackPanel Spacing="12">
                    <!-- 网易/B站用户信息栏 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Grid Width="40" Height="40" Margin="0,0,12,0">
                            <Border CornerRadius="20" BorderBrush="#FB7299" BorderThickness="1.5" ClipToBounds="True">
                                <Image Source="{Binding Avatar}" Width="40" Height="40" Stretch="UniformToFill"/>
                            </Border>
                            <Border Background="#FFB020" Width="14" Height="14" CornerRadius="7" 
                                    BorderBrush="{StaticResource YellowVBorder}" BorderThickness="1" 
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,-2">
                                <TextBlock Text="⚡" FontSize="8" Foreground="White" FontWeight="Bold" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding AuthorName}" Foreground="{DynamicResource CardTextPrimary}" FontSize="14" FontWeight="Bold"/>
                                <Border Background="#FB7299" CornerRadius="4" Padding="5,2" VerticalAlignment="Center">
                                    <TextBlock Text="UP" Foreground="White" FontSize="9" FontWeight="Black" Margin="0,-1,0,0"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding AuthorMeta}" Foreground="{DynamicResource CardTextMuted}" FontSize="11" FontWeight="Medium"/>
                        </StackPanel>
                    </Grid>

                    <!-- 标题及描述 -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding Title}" 
                                   Foreground="{DynamicResource CardTextPrimary}" FontSize="16" FontWeight="Heavy" 
                                   TextWrapping="Wrap" LineHeight="22" />
                        
                        <TextBlock Text="{Binding Description}" 
                                   Foreground="{DynamicResource CardTextSecondary}" FontSize="12" 
                                   TextWrapping="Wrap" LineHeight="18" />
                    </StackPanel>

                    <!-- 标签栏 (优化: 使用了新的 CardTagText 前景色) -->
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{DynamicResource CardTagBg}" CornerRadius="6" Padding="8,4">
                            <TextBlock Text="{Binding TagsText}" Foreground="{DynamicResource CardTagText}" FontSize="11" FontWeight="Medium"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- 底部数据栏 -->
                <Border Background="{DynamicResource CardPanelBg}" BorderBrush="{DynamicResource CardPanelBorder}" BorderThickness="1" CornerRadius="12" Padding="8,10">
                    <UniformGrid Columns="4">
                        <StackPanel Spacing="6" HorizontalAlignment="Center" Orientation="Horizontal">
                            <Path Data="M1 21h4V9H1v12zm22-11c0-1.1-.9-2-2-2h-6.31l.95-4.57.03-.32c0-.41-.17-.79-.44-1.06L14.17 1 7.59 7.59C7.22 7.95 7 8.45 7 9v10c0 1.1.9 2 2 2h9c.83 0 1.54-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-2z" 
                                  Fill="#FB7299" Width="16" Height="16" Stretch="Uniform"/>
                            <TextBlock Text="{Binding LikeCount}" Foreground="#FB7299" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Spacing="6" HorizontalAlignment="Center" Orientation="Horizontal">
                            <Path Data="M14.045 25.5454C7.69377 25.5454 2.54504 20.3967 2.54504 14.0454C2.54504 7.69413 7.69377 2.54541 14.045 2.54541C20.3963 2.54541 25.545 7.69413 25.545 14.0454C25.545 17.0954 24.3334 20.0205 22.1768 22.1771C20.0201 24.3338 17.095 25.5454 14.045 25.5454ZM9.66202 6.81624H18.2761C18.825 6.81624 19.27 7.22183 19.27 7.72216C19.27 8.22248 18.825 8.62807 18.2761 8.62807H14.95V10.2903C17.989 10.4444 20.3766 12.9487 20.3855 15.9916V17.1995C20.3854 17.6997 19.9799 18.1052 19.4796 18.1052C18.9793 18.1052 18.5738 17.6997 18.5737 17.1995V15.9916C18.5667 13.9478 16.9882 12.2535 14.95 12.1022V20.5574C14.95 21.0577 14.5444 21.4633 14.0441 21.4633C13.5437 21.4633 13.1382 21.0577 13.1382 20.5574V12.1022C11.1 12.2535 9.52148 13.9478 9.51448 15.9916V17.1995C9.5144 17.6997 9.10883 18.1052 8.60856 18.1052C8.1083 18.1052 7.70273 17.6997 7.70265 17.1995V15.9916C7.71158 12.9487 10.0992 10.4444 13.1382 10.2903V8.62807H9.66202C9.11309 8.62807 8.66809 8.22248 8.66809 7.72216C8.66809 7.22183 9.11309 6.81624 9.66202 6.81624Z" 
                                  Fill="#00AEEC" Width="16" Height="16" Stretch="Uniform"/>
                            <TextBlock Text="{Binding CoinCount}" Foreground="#00AEEC" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Spacing="6" HorizontalAlignment="Center" Orientation="Horizontal">
                            <Path Data="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" 
                                  Fill="#E79F1D" Width="16" Height="16" Stretch="Uniform"/>
                            <TextBlock Text="{Binding CollectCount}" Foreground="#E79F1D" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Spacing="6" HorizontalAlignment="Center" Orientation="Horizontal">
                            <Path Data="M10 9V5l-7 7 7 7v-4.1c5 0 8.5 1.6 11 5.1-1-5-4-10-11-11z" 
                                  Fill="{DynamicResource CardShareColor}" Width="16" Height="16" Stretch="Uniform"/>
                            <TextBlock Text="{Binding ShareCount}" Foreground="{DynamicResource CardShareColor}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </UniformGrid>
                </Border>

            </StackPanel>
        </Grid>
    </Border>
</UserControl>
